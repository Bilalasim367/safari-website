generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("TURSO_DATABASE_URL")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([slug])
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  description      String?
  price            Float
  originalPrice   Float?
  image            String
  images           String
  categoryId       String?
  category         Category?    @relation(fields: [categoryId], references: [id])
  categorySlug     String?      @default("unisex")
  size             String       @default("50ml")
  sizePrices       String       @default("[]")
  fragranceFamily  String?
  rating           Float        @default(0)
  reviewCount      Int          @default(0)
  notesTop         String
  notesHeart       String
  notesBase        String
  inStock          Boolean      @default(true)
  isBestseller     Boolean      @default(false)
  isNew            Boolean      @default(false)
  isHotSelling     Boolean      @default(false)
  isTrending       Boolean      @default(false)

  // Bulk upload fields (additive, optional)
  productId        String?      @unique
  gender           String       @default("Unisex")
  type             String       @default("Attar")
  season           String?
  bestTime         String?
  impressionOf     String?
  shortDescription String?
  longDescription  String?
  tags             String?
  sizesAvailable   String       @default("3ml,6ml,12ml,50ml")

  // Perfume-specific attributes
  concentration    String?      // EDP, EDT, Parfum, Extrait
  bottleStyle      String?      // Spray, Atomizer, Splash, Decant
  longevity        String?      // Very Long, Long, Moderate, Light
  sillage          String?      // Heavy, Moderate, Soft, Intimate

  // Attar-specific attributes
  applicatorType   String?      // roll-on, stick, premium-box
  origin           String?      // Sourcing region e.g. Assam, India
  ingredients      String?      // Ingredient list
  price3mlPhysical Int?
  price6mlPhysical Int?
  price12mlPhysical Int?
  price50mlPhysical Int?
  price3mlOnline   Int?
  price6mlOnline   Int?
  price12mlOnline  Int?
  price50mlOnline  Int?
  currency         String       @default("PKR")
  oilPricePer100g  Int?
  supplier         String?
  isFeatured       Boolean      @default(false)
  isActive         Boolean      @default(true)
  stockStatus      String       @default("in_stock")
  imageFolder      String?
  metaTitle        String?
  metaDescription  String?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  bundleItems BundleItem[]

  @@index([categorySlug, isBestseller])
  @@index([categorySlug, isNew])
}

model Bundle {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  price         Float
  originalPrice Float?
  image         String?
  save          String?
  size          String?
  inStock       Boolean  @default(true)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items BundleItem[]

  @@index([isActive])
}

model BundleItem {
  id        String   @id @default(cuid())
  bundleId  String
  bundle    Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)

  @@unique([bundleId, productId])
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  avatar    String?
  role      String   @default("customer")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLogin DateTime?
  resetCode      String?
  resetCodeExpiry DateTime?

  addresses Address[]
  cart      CartItem[]
  wishlist   WishlistItem[]
  orders    Order[]
  notifications Notification[]

  @@index([email, role])
}

model Address {
  id        String  @id @default(cuid())
  firstName String?
  lastName  String?
  address1 String?
  address2 String?
  city     String?
  state    String?
  zipCode  String?
  country  String  @default("US")
  phone    String?
  isDefault Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CartItem {
  id        String  @id @default(cuid())
  productId String
  name      String
  price     Float
  image     String?
  size      String?
  quantity  Int     @default(1)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WishlistItem {
  id        String  @id @default(cuid())
  productId String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id             String   @id @default(cuid())
  orderNumber    String   @unique
  userId         String?
  user           User?     @relation(fields: [userId], references: [id])
  customerName  String
  customerEmail String
  items         OrderItem[]
  subtotal      Float
  shipping     Float     @default(0)
  tax          Float     @default(0)
  total        Float
  status       String    @default("pending")
  paymentStatus String @default("pending")
  shippingAddress String?
  trackingNumber String?
  shippedAt      DateTime?
  estimatedDelivery DateTime?
  createdAt    DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  productId String?
  name      String
  price     Float
  quantity  Int
  size      String?
  image     String?

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  type      String   @default("system")
  title     String
  message   String
  read      Boolean  @default(false)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  productId String
  customerName  String
  rating    Int
  text      String
  date      DateTime @default(now())
  isApproved Boolean @default(true)

  @@index([productId])
  @@index([isApproved])
}

model Settings {
  id                   String   @id @default(cuid())
  storeName            String   @default("My Store")
  storeEmail           String?
  storePhone          String?
  storeAddress        String?
  currency            String   @default("PKR")
  timezone            String   @default("America/New_York")
  taxRate             Float    @default(0)
  shippingFee         Float    @default(0)
  freeShippingThreshold Float  @default(0)
  emailNotifications  Boolean  @default(true)
  orderEmails         Boolean  @default(true)
  marketingEmails    Boolean  @default(false)
  smtpHost            String?
  smtpPort            Int?
  smtpUser            String?
  smtpPassword        String?
  metaTitle           String?
  metaDescription     String?
  metaKeywords       String?
  updatedAt           DateTime @updatedAt
}
